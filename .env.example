# CommentaryFlow — environment variables
# Copy to .env and fill in values. API key can also be set via the Settings UI.

# OpenAI API Key (required for generation)
# Get your key from: https://platform.openai.com/api-keys
# Alternatively, set this in the app via Settings → OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# Optional: override the JWT secret (default is fine for local dev only)
# CF_SECRET_KEY=change-this-to-a-random-32-char-string-in-prod
